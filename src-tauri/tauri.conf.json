{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "speeddf",
	"version": "0.5.0",
	"identifier": "com.speeddf.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "speeddf",
				"width": 800,
				"height": 600,
				"resizable": true,
				"decorations": false,
				"visible": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"minimumSystemVersion": "11.0"
		},
		"fileAssociations": [
			{
				"ext": [
					"pdf"
				],
				"name": "speedDF Document",
				"role": "Editor",
				"description": "Portable Document Format handled by speedDF",
				"mimeType": "application/pdf"
			}
		]
	}
}