{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "speeddf",
	"version": "0.2.0",
	"identifier": "com.terryminett.speeddf",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "speeddf",
				"width": 800,
				"height": 600,
				"resizable": true,
				"decorations": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "speedDF Document",
        "description": "Portable Document Format handled by speedDF"
      }
    ]
  }
}